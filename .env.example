# LLM provider: "deepseek" or "azure_openai"
LLM_PROVIDER=deepseek

# --- DeepSeek ---
# DeepSeek API Key (get it from platform.deepseek.com)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# --- Azure OpenAI (set LLM_PROVIDER=azure_openai to use) ---
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_API_KEY=your_azure_api_key_here
# AZURE_OPENAI_DEPLOYMENT_NAME=your-deployment-name
# AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Chunk size for sequential processing (lines per chunk)
LINES_PER_CHUNK=500
# Overlap between consecutive chunks to prevent mid-field splits
OVERLAP_LINES=50

# Optional: LangSmith Tracing (highly recommended for debugging LangGraph)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your_langsmith_api_key_here
# LANGCHAIN_PROJECT=langgraph-deepseek-starter
